# Ubuntu 22.04 / GCC 11
CompileFlags:
  Add: 
    - "-std=c++17"
    - "-I/usr/include/c++/11"
    - "-I/usr/include/x86_64-linux-gnu/c++/11"
    - "-I/usr/include/c++/11/backward"
    - "-I/usr/lib/gcc/x86_64-linux-gnu/11/include"
    - "-I/usr/local/include"
    - "-I/usr/include/x86_64-linux-gnu"
    - "-I/usr/include"
    - "-I${workspaceFolder}/src"
    - "-I${workspaceFolder}/install/robot_msgs/include"
    - "-I/opt/ros/humble/include"
  Remove: "-W*"

Index:
  Background: Build

Diagnostics:
  ClangTidy:
    Add: 
      - performance-*
      - modernize-*
    Remove: modernize-use-trailing-return-type

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
